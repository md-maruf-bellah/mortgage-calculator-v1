# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/mortgage-calculator

# MongoDB Atlas (cloud) — recommended for production
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/mortgage-calculator

# ─── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=mortgageiq-access-secret-change-me-in-production
JWT_REFRESH_SECRET=mortgageiq-refresh-secret-change-me-in-production

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Seed Script ───────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@mortgageiq.com
SEED_ADMIN_PASSWORD=Admin@1234
